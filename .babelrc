{
  "comments": false,
  "env": {
    "main": {
      "presets": [
        "@babel/preset-env"
      ]
    },
    "renderer": {
      "presets": [
        "@babel/preset-env"
      ]
    },
    "web": {
      "presets": [
        "@babel/preset-env"
      ]
    }
  },
  "plugins": [
    "@babel/plugin-proposal-class-properties",
    "@babel/plugin-transform-runtime"
  ]
}