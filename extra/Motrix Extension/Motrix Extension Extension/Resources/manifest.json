{
    "manifest_version": 3,
    "name": "Motrix",
    "version": "1.0",
    "description": "Download with Motrix",
    "icons": {
        "48": "images/icon-48.png",
        "128": "images/icon-128.png"
    },
    "permissions": [
        "contextMenus",
        "storage"
    ],
    "host_permissions": [
        "http://127.0.0.1:16800/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "action": {
        "default_icon": {
            "48": "images/icon-48.png"
        },
        "default_title": "Motrix"
    }
}